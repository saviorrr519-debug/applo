{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A construction project tracking document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "location": { "type": "string" },
        "targetCompletion": { "type": "string" },
        "budget": { "type": "string" },
        "overallProgress": { "type": "integer" },
        "manager": { "type": "string" },
        "status": { "type": "string", "enum": ["Aktif", "Selesai", "Tertunda"] },
        "description": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      },
      "required": ["id", "name", "location", "targetCompletion", "budget", "overallProgress", "manager", "status", "description"]
    },
    "ProjectProgressReport": {
      "title": "ProjectProgressReport",
      "description": "A field report of progress for a specific project",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "projectName": { "type": "string" },
        "location": { "type": "string" },
        "reporterName": { "type": "string" },
        "reporterRole": { "type": "string", "enum": ["Pekerja Lapangan", "Pengawas", "Kontraktor"] },
        "date": { "type": "string" },
        "progressPercentage": { "type": "integer" },
        "description": { "type": "string" },
        "photoUrl": { "type": "string" },
        "photoUrls": { "type": "array" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "timestamp": { "type": "integer" },
        "approvalStatus": { "type": "string", "enum": ["Pending", "Disetujui", "Perlu Revisi"] },
        "managementFeedback": { "type": "string" }
      },
      "required": ["id", "projectId", "projectName", "location", "reporterName", "reporterRole", "date", "progressPercentage", "description", "category", "status", "timestamp"]
    },
    "NotificationAlert": {
      "title": "NotificationAlert",
      "description": "An alert notification for a system action",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "error"] },
        "timestamp": { "type": "integer" },
        "read": { "type": "boolean" },
        "reportId": { "type": "string" }
      },
      "required": ["id", "title", "message", "type", "timestamp", "read"]
    },
    "SchedulerSettings": {
      "title": "SchedulerSettings",
      "description": "Configuration settings for automatic report generation",
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "frequency": { "type": "string", "enum": ["weekly", "daily", "monthly"] },
        "dayOfWeek": { "type": "integer" },
        "time": { "type": "string" },
        "recipientEmail": { "type": "string" },
        "includePdf": { "type": "boolean" },
        "includeSheets": { "type": "boolean" },
        "lastRunTimestamp": { "type": "integer" },
        "nextRunTimestamp": { "type": "integer" }
      },
      "required": ["enabled", "frequency", "dayOfWeek", "time", "recipientEmail", "includePdf", "includeSheets"]
    },
    "CompiledWeeklySummary": {
      "title": "CompiledWeeklySummary",
      "description": "A generated weekly executive summary document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "compiledAt": { "type": "string" },
        "totalReports": { "type": "integer" },
        "averageProgress": { "type": "integer" },
        "progressGained": { "type": "number" },
        "projectBreakdown": { "type": "array" },
        "categoryBreakdown": { "type": "array" },
        "keyHighlights": { "type": "array" },
        "pendingApprovals": { "type": "integer" },
        "isAutoGenerated": { "type": "boolean" }
      },
      "required": ["id", "title", "startDate", "endDate", "compiledAt", "totalReports", "averageProgress", "progressGained", "projectBreakdown", "categoryBreakdown", "keyHighlights", "pendingApprovals", "isAutoGenerated"]
    }
  },
  "firestore": {
    "projects": {
      "schema": "Project",
      "description": "List of active trackable projects"
    },
    "reports": {
      "schema": "ProjectProgressReport",
      "description": "List of submitted project progress reports"
    },
    "notifications": {
      "schema": "NotificationAlert",
      "description": "Notification alerts for PMO events"
    },
    "schedulerSettings": {
      "schema": "SchedulerSettings",
      "description": "Singleton configuration for PMO report scheduling"
    },
    "compiledSummaries": {
      "schema": "CompiledWeeklySummary",
      "description": "Archives of compiled weekly summaries"
    }
  }
}
