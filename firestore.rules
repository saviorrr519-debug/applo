rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidProject(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.location is string && data.location.size() <= 200
        && data.targetCompletion is string && data.targetCompletion.size() <= 100
        && data.budget is string && data.budget.size() <= 100
        && data.overallProgress is int && data.overallProgress >= 0 && data.overallProgress <= 100
        && data.manager is string && data.manager.size() <= 100
        && data.status is string && (data.status == 'Aktif' || data.status == 'Selesai' || data.status == 'Tertunda')
        && data.description is string && data.description.size() <= 1000;
    }

    function isValidReport(data) {
      return data.id is string && data.id.size() <= 128
        && data.projectId is string && data.projectId.size() <= 128
        && data.projectName is string && data.projectName.size() <= 200
        && data.location is string && data.location.size() <= 200
        && data.reporterName is string && data.reporterName.size() <= 200
        && data.reporterRole is string && (data.reporterRole == 'Pekerja Lapangan' || data.reporterRole == 'Pengawas' || data.reporterRole == 'Kontraktor')
        && data.date is string && data.date.size() <= 100
        && data.progressPercentage is int && data.progressPercentage >= 0 && data.progressPercentage <= 100
        && data.description is string && data.description.size() <= 2000000 // generous for inline photo data if any
        && data.category is string && data.category.size() <= 100
        && data.status is string && data.status.size() <= 100
        && data.timestamp is int;
    }

    function isValidNotification(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.type is string && (data.type == 'info' || data.type == 'success' || data.type == 'warning' || data.type == 'error')
        && data.timestamp is int
        && data.read is bool;
    }

    function isValidScheduler(data) {
      return data.enabled is bool
        && data.frequency is string && (data.frequency == 'weekly' || data.frequency == 'daily' || data.frequency == 'monthly')
        && data.dayOfWeek is int && data.dayOfWeek >= 0 && data.dayOfWeek <= 6
        && data.time is string && data.time.size() <= 10
        && data.recipientEmail is string && data.recipientEmail.size() <= 200
        && data.includePdf is bool
        && data.includeSheets is bool;
    }

    function isValidSummary(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.startDate is string && data.startDate.size() <= 50
        && data.endDate is string && data.endDate.size() <= 50
        && data.compiledAt is string && data.compiledAt.size() <= 50
        && data.totalReports is int && data.totalReports >= 0
        && data.averageProgress is int && data.averageProgress >= 0 && data.averageProgress <= 100
        && (data.progressGained is int || data.progressGained is float || data.progressGained == 0)
        && data.projectBreakdown is list
        && data.categoryBreakdown is list
        && data.keyHighlights is list
        && data.pendingApprovals is int && data.pendingApprovals >= 0
        && data.isAutoGenerated is bool;
    }

    // --- Collection Rule Declarations ---

    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(projectId) && isValidProject(incoming());
      allow update: if isSignedIn() && isValidId(projectId) && isValidProject(incoming());
      allow delete: if isSignedIn() && isValidId(projectId);
    }

    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(reportId) && isValidReport(incoming());
      allow update: if isSignedIn() && isValidId(reportId) && isValidReport(incoming());
      allow delete: if isSignedIn() && isValidId(reportId);
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming());
      allow update: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming());
      allow delete: if isSignedIn() && isValidId(notificationId);
    }

    match /schedulerSettings/{settingsId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(settingsId) && isValidScheduler(incoming());
      allow update: if isSignedIn() && isValidId(settingsId) && isValidScheduler(incoming());
      allow delete: if isSignedIn() && isValidId(settingsId);
    }

    match /compiledSummaries/{summaryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(summaryId) && isValidSummary(incoming());
      allow update: if isSignedIn() && isValidId(summaryId) && isValidSummary(incoming());
      allow delete: if isSignedIn() && isValidId(summaryId);
    }
  }
}
